// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Administrateur de la boutique
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin") // "admin" ou "super_admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Catégories de produits (plomberie, électricité, etc.)
model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  icon        String?   // Nom de l'icône Lucide
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Produits de la quincaillerie
model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  price       Float
  oldPrice    Float?    // Prix avant promotion
  image       String?
  images      String?   // JSON array d'images supplémentaires
  stock       Int       @default(0)
  sku         String?   // Code produit
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  featured    Boolean   @default(false) // Produit en vedette
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  orderItems  OrderItem[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Commandes des clients
model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerPhone String
  customerEmail String?
  customerAddress String?
  status        String      @default("pending") // pending, confirmed, shipped, delivered, cancelled
  total         Float
  notes         String?
  whatsappSent  Boolean     @default(false)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// Articles dans une commande
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   // Prix au moment de la commande
}

// Paramètres de la boutique
model Setting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Promotions
model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String?
  discount    Float    // Pourcentage de réduction
  code        String?  // Code promo optionnel
  startDate   DateTime
  endDate     DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Agents DRH - Personnel de la mairie
model Agent {
  id            String   @id @default(cuid())
  matricule     String   @unique
  nom           String
  prenom        String
  email         String?
  telephone     String?
  direction     String
  service       String?
  fonction      String?
  dateEntree    DateTime?
  soldeConges   Int      @default(30)
  password      String
  role          String   @default("agent") // "agent", "responsable", "admin"
  active        Boolean  @default(true)
  conges        Conge[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Demandes de congés
model Conge {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
  type        String   // "annuel", "exception", "maladie", "maternite", etc.
  dateDebut   DateTime
  dateFin     DateTime
  nbJours     Int
  motif       String?
  statut      String   @default("en_attente") // "en_attente", "approuve", "refuse"
  approuvePar String?
  dateApprouve DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Notifications
model Notification {
  id        String   @id @default(cuid())
  agentId   String
  title     String
  message   String
  type      String   @default("info") // "info", "warning", "success", "error"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Choix annuels de congés
model ChoixAnnuel {
  id        String   @id @default(cuid())
  agentId   String
  annee     Int
  periode1  String?  // Premier choix de période
  periode2  String?  // Deuxième choix de période
  periode3  String?  // Troisième choix de période
  statut    String   @default("en_attente")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
